# ======================================================================================
# AUTOGENERATED HYPRLAND CONFIG.
# EDIT THIS CONFIG ACCORDING TO THE WIKI INSTRUCTIONS.
# ======================================================================================
# 这是 Hyprland 的主配置文件。Hyprland 保存此文件后会自动重载，也可以用
# `hyprctl reload` 手动触发。配置可以用 source = 拆成多个子文件来管理。

################
### MONITORS ###
################
# 显示器配置
# 语法：monitor = 名称, 分辨率@刷新率, X偏移x Y偏移, 缩放倍率 [, 额外参数]
# preferred = 自动选取驱动上报的最优分辨率；auto = 自动选取刷新率/缩放
# mirror,eDP-1 = 把这块屏幕设为 eDP-1 的镜像

monitor=eDP-1,preferred,auto,auto
monitor=HDMI-A-1,preferred,auto,auto,mirror,eDP-1

# xwayland 块：控制 XWayland 兼容层行为
# force_zero_scaling = true：强制 XWayland 应用按 1:1 渲染，再由合成器缩放，
# 避免某些旧应用（如旧版 WPS、腾讯会议）在 HiDPI 下模糊或字体错位
# 禁用xwayland缩放
xwayland {
  force_zero_scaling = true
}

# cursor 块：控制光标全局行为
# no_warps = true：切换焦点时光标不会自动"传送"到新窗口中心，保持光标物理位置
# 鼠标不会随聚焦切换到窗口中心
cursor {
	no_warps = true
}

###################
### MY PROGRAMS ###
###################
# 用 $ 变量统一管理常用程序路径/命令，方便后续 bind 直接引用；改程序只需改这里

$terminal = kitty                            # 默认终端
$fileManager = thunar                        # 默认文件管理器
$menu = dms ipc call launcher toggle         # 通过 DMS IPC 调用启动器（显示/隐藏切换）
$browser = zen-browser                           # 默认浏览器
$clipboard = dms ipc call clipboard toggle   # 通过 DMS IPC 调用剪贴板管理（显示/隐藏）

#################
### AUTOSTART ###
#################
# exec-once = 命令：仅在 Hyprland 启动时执行一次，不会在 hyprctl reload 时重复运行

exec-once = dms run                          # 启动 DMS（DankShell 生态核心：壁纸/状态栏/IPC等）
exec-once = sleep 3 && fcitx5 -d             # 延迟 3s 后台运行 fcitx5 输入法；
                                             # 延迟是为了等 Hyprland + portal 完全就绪，
                                             # 避免输入法在环境变量未加载时启动导致无法用中文
exec-once = xhost +si:localuser:root         # 允许 root 用户访问当前用户的 X11 显示
                                             # 目的：让需要以 root 运行的 GUI 程序（如 gparted）
                                             # 能正常显示窗口

#############################
### ENVIRONMENT VARIABLES ###
#############################
env = KEY,VALUE

# 向 Hyprland 及其所有子进程注入环境变量
# 注意：这里设置的和末尾 source = ./dms/cursor.conf 里的 cursor 环境变量会重复，
# 后者（source 在文件末尾）会覆盖这里的值

env = XCURSOR_SIZE,24                 # 传统 X11 光标大小（给 XWayland 应用使用）
env = HYPRCURSOR_SIZE,24              # 新式 Hyprcursor 光标大小（给原生 Wayland 应用使用）
env = QT_QPA_PLATFORMTHEME,gtk3       # 让 Qt5 应用读取 GTK3 主题（按钮/字体/配色统一）
env = QT_QPA_PLATFORMTHEME_QT6,gtk3   # 同上，适用于 Qt6 应用
env = QS_ICON_THEME,Adwaita           # 设置 Quickshell（你的 DMS 状态栏）使用的图标主题
env = XMODIFIERS,@im=fcitx            # 告知 X11 程序使用 fcitx 作为输入法框架
env = QT_IM_MODULES,fcitx             # 告知 Qt 程序通过 fcitx 模块处理输入
env = LANGUAGE,zh_CN.UTF-8            # 优先语言列表（影响程序菜单/提示语言）
env = LANG,zh_CN.UTF-8                # 全局 locale（决定日期格式、排序、语言）
env = LC_CTYPE,en_US.UTF-8            # 单独覆盖字符分类 locale 为英文 UTF-8，
                                      # 目的：保持终端下英文字符处理正常，
                                      # 避免某些程序在纯中文 locale 下出现编码问题

###################
### PERMISSIONS ###
###################
# Hyprland 权限系统（新版安全功能，目前注释掉代表不启用）
# enforce_permissions = 1 开启后，只有显式授权的程序才能截图/使用插件等敏感操作
# 修改此处需要完全重启 Hyprland（hyprctl reload 不生效，因为涉及安全边界）

# ecosystem {
#   enforce_permissions = 1
# }
# permission = /usr/(bin|local/bin)/grim, screencopy, allow         # 允许 grim 截图
# permission = /usr/(lib|libexec|lib64)/xdg-desktop-portal-hyprland, screencopy, allow
# permission = /usr/(bin|local/bin)/hyprpm, plugin, allow           # 允许 hyprpm 插件管理

#####################
### LOOK AND FEEL ###
#####################

# 自定义颜色变量（可在后续配置中用 $color1 引用）
$color1=rgba(33ccffee)

general {
    # 窗口间距
    gaps_in = 3         # 相邻窗口之间的间距（像素）
    gaps_out = 5        # 窗口距屏幕边缘的间距（像素）

    border_size = 0     # 窗口边框宽度（像素），0 表示无边框

    # 边框颜色：使用 rgba(RRGGBBAA) 格式
    # 末尾 45deg 表示渐变角度（可写多个颜色实现渐变边框）
    col.active_border =  rgba(00ff99ee) 45deg   # 当前聚焦窗口的边框颜色
    col.inactive_border = rgba(595959aa)        # 未聚焦窗口的边框颜色
    # 注意：colors.conf (source 在文件末尾) 会覆盖上面两个颜色值

    # resize_on_border = false：拖拽边框/间隙时不触发缩放窗口
    # 改为 true 可以直接拖边框来调整窗口大小（类似 i3）
    resize_on_border = false

    # allow_tearing = false：禁止画面撕裂
    # 开启撕裂可以减少游戏延迟，但会有视觉瑕疵；配合 windowrule 可只对游戏开启
    allow_tearing = false

    layout = scrolling  # 全局布局引擎：scrolling（横向卷轴式平铺）
                        # 其他选项：dwindle（螺旋分割）/ master（主从布局）
                        # 可用 Super+Shift+1/2/3 实时切换

    # no_focus_fallback = true：焦点到达边缘时不会"环绕"跳到对面的窗口
    # 类比：像地图到达边界就停住，而不是从另一侧出现
    no_focus_fallback = true
}

decoration {
    rounding = 8          # 窗口圆角半径（像素），0 = 直角，值越大越圆
    rounding_power = 2    # 圆角平滑算法的幂次：2.0 = 标准圆，值越大越接近直角过渡

    # 窗口透明度（1.0 = 完全不透明，0.0 = 完全透明）
    active_opacity = 0.9    # 当前聚焦窗口的不透明度
    inactive_opacity = 0.8  # 未聚焦窗口的不透明度（这里两者相同，意味着无透明差异）

    shadow {
        enabled = true             # 开启窗口阴影
        range =3                  # 阴影扩散半径（像素），越大阴影越模糊扩散
        render_power = 1           # 阴影衰减强度（1-4），值越大阴影越"深"越实
        color = rgba(1a1a1aee)     # 阴影颜色（深灰色，不透明度 ee ≈ 93%）
    }

    blur {
        enabled = true    # 开启背景模糊（毛玻璃效果）
        # xray = on：X光模式（穿透模糊）
        # 普通窗口使用xray可以减少性能开销
        # 原理：xray=on 时浮动窗口直接透过看到最底层壁纸并模糊，
        # 而非采样下方所有窗口叠加模糊（后者开销远更大）
        xray = on
        size = 1          # 模糊采样半径，值越大模糊范围越宽
        passes = 0        # 模糊迭代次数，次数越多效果越细腻（但 GPU 开销也线性增加）
        noise = 0.02      # 在模糊层加入轻微噪点，避免模糊区域过于"塑料感"

        vibrancy = 0.2    # 提升模糊背景的色彩饱和度（0=不增强，1=最大增强）
        contrast = 1.0    # 提升模糊背景的对比度（1.0=原始，>1 更鲜明，<1 更灰）
    }
}

animations {
    enabled = yes, please :)   # 开启全局动画（Hyprland 只检查第一个词 yes/no）

    # 贝塞尔曲线：定义动画速度随时间的变化规律（缓动函数）
    # 语法：bezier = 名称, P1x, P1y, P2x, P2y（三次贝塞尔曲线控制点）
    # 可以用 https://cubic-bezier.com 可视化预览效果
    bezier = easeOutQuint,   0.23, 1,    0.32, 1    # 快速减速，适合窗口弹出感
    bezier = easeInOutCubic, 0.65, 0.05, 0.36, 1    # 先慢后快再慢，适合平滑过渡
    bezier = linear,         0,    0,    1,    1    # 匀速，适合淡出等线性动画
    bezier = almostLinear,   0.5,  0.5,  0.75, 1    # 接近匀速但末尾略微减速
    bezier = quick,          0.15, 0,    0.1,  1    # 极速启动、快速完成
    bezier = overshot,       0.18, 0.95, 0.22, 1.03 # 末尾轻微超出再弹回（弹性感）

    # 动画配置
    # 语法：animation = 名称, 开关(1/0), 速度, 曲线名称, [风格]
    # 速度单位：以 100ms 为基准，速度=5 表示约 0.5s，数值越大越慢
    # 风格（style）：slide/popin/fade 等，控制窗口进出的方向/形态

    animation = global,        1,  10,    default       # 全局默认动画（其他未覆盖的都走这里）
    animation = border,        1,  5.39,  easeOutQuint  # 边框颜色切换动画
    animation = windows,       1,  4.79,  easeOutQuint  # 窗口移动/缩放通用动画
    animation = windowsIn,     1,  4.1,   easeOutQuint, popin 87%  # 窗口打开：从 87% 大小弹出
    animation = windowsOut,    1,  1.49,  linear,       popin 87%  # 窗口关闭：快速缩回 87%
    animation = fadeIn,        1,  1.73,  almostLinear  # 窗口淡入（透明度从0到目标值）
    animation = fadeOut,       1,  1.46,  almostLinear  # 窗口淡出
    animation = fade,          1,  3.03,  quick         # 通用淡入淡出（如失去焦点变暗）
    animation = layers,        1,  3.81,  easeOutQuint  # 图层（如 Waybar、通知）通用动画
    animation = layersIn,      1,  4,     easeOutQuint, fade  # 图层出现：淡入
    animation = layersOut,     1,  1.5,   linear,       fade  # 图层消失：线性淡出
    animation = fadeLayersIn,  1,  1.79,  almostLinear  # 图层淡入的透明度动画
    animation = fadeLayersOut, 1,  1.39,  almostLinear  # 图层淡出的透明度动画
    animation = workspaces,    1,  4.5,   overshot, slidevert  # 切换工作区：垂直滑动+弹性超出
    animation = zoomFactor,    1,  7,     quick         # 概览缩放（如 fake-overview 脚本用）
}

# Smart Gaps（仅一个窗口时去除间距），目前已注释，需要时取消注释即可
# workspace = w[tv1], gapsout:0, gapsin:0
# workspace = f[1], gapsout:0, gapsin:0

# dwindle 布局配置（当 layout = dwindle 时生效）
dwindle {
    pseudotile = true    # 伪平铺开关：启用后可让"浮动"窗口保持平铺位置/大小约束
                         # 用 Super+P 切换（见下方键位区）
    preserve_split = true # 保持分割方向：调整窗口大小时不影响相邻窗口的分割比例
}

# master 布局配置（当 layout = master 时生效）
master {
    new_status = master  # 新打开的窗口默认成为"主窗口"（占据主区域）
                         # 其他选项：slave（放入从属区域）
}

# scrolling 布局配置（你当前主力布局）
# 原理：窗口横向排列成"列"，每列可以纵向堆叠多个窗口，像电影胶片一样横向延伸
scrolling {
    # 只有一个窗口时默认最大化`
    fullscreen_on_one_column=true    # 当一列中只有一个窗口时，自动撑满整个屏幕

    # 滚动布局预设宽度
    explicit_column_widths=0.333, 0.5, 0.667  # 按 Super+R 循环切换列宽的预设值
                                               # 分别对应 1/3、1/2、2/3 屏幕宽度

    # 新窗口出现的方向，上下左右
    direction=right    # 新窗口出现在当前焦点窗口的右侧（创建新列）
}

misc {
    force_default_wallpaper = 0 # 控制 Hyprland 内置壁纸：-1=随机动漫壁纸，0/1=固定图
    disable_hyprland_logo = false # false=保留启动时随机 Hyprland Logo 动漫背景
}

#############
### INPUT ###
#############

input {
    kb_layout = us    # 键盘布局：us = 美式英语标准布局
    kb_variant =      # 布局变体（留空=默认），如 dvorak、colemak 等
    kb_model =        # 键盘型号（通常留空）
    kb_options =      # 附加选项（如 caps:swapescape 交换 Caps 和 Esc）
    kb_rules =        # XKB 规则文件（通常留空）

    # 跟随鼠标切换聚焦
    # follow_mouse：控制焦点跟随鼠标的方式
    # 0 = 点击才切换焦点（当前设置）
    # 1 = 鼠标移入窗口即切换焦点
    # 2 = 同 1 但移动到空白区域不失焦
    # 3 = 同 0 但同时保持鼠标附近窗口在前台
    follow_mouse = 1
    accel_profile= flat  # 鼠标加速曲线：flat = 完全线性（禁用系统加速）
                         # 其他选项：adaptive（自适应加速）
    sensitivity = 0      # 灵敏度增益系数：范围 -1.0 到 1.0，0 = 不修改原始移动量

    touchpad {
        natural_scroll = true  # 自然滚动：手指向下滑 = 内容向下滚（跟手）
                               # false = 传统方向（手指向下 = 内容向上）
    }
}

# 多指手势（Hyprland 原生手势支持）
# 语法：gesture = 手指数, 方向, dispatcher, [参数...]
gesture = 3, vertical, workspace              # 三指上下滑动：切换工作区（上一个/下一个）
gesture = 3, right, dispatcher, movefocus, l  # 三指右划：把焦点移到左边的窗口
gesture = 3, left, dispatcher, movefocus, r   # 三指左划：把焦点移到右边的窗口

# 针对特定设备单独配置（此处是示例，epic-mouse-v1 是占位名称）
# 真实设备名用 hyprctl devices 查看
device {
    name = epic-mouse-v1
    sensitivity = -0.5    # 该设备专属灵敏度，覆盖全局 sensitivity 设置
}

###################
### KEYBINDINGS ###
###################
# bind 语法：bind = 修饰键, 按键, dispatcher, [参数]
# 修饰键可叠加：SUPER SHIFT CTRL ALT
# 常用 dispatcher：exec(运行命令), workspace, movetoworkspace,
#                  movefocus, movewindow, togglefloating, fullscreen, killactive 等
# 特殊标志（写在第一个逗号前）：
#   e = 按住重复触发（适合音量/亮度这类需要连续调节的）
#   l = 锁屏状态下也生效（适合多媒体键）
#   m = 鼠标按键绑定（bindm）

$mainMod = SUPER  # 定义主修饰键为 Win 键（SUPER）

# ---- 布局实时切换（通过 hyprctl keyword 动态修改 general:layout）----
# 好处：不需要重载配置文件，立即生效
bind = $mainMod SHIFT, 1, exec, hyprctl keyword  general:layout scrolling  # 切换到 scrolling 布局
bind = $mainMod SHIFT, 2, exec, hyprctl keyword  general:layout dwindle    # 切换到 dwindle 布局
bind = $mainMod SHIFT, 3, exec, hyprctl keyword  general:layout master     # 切换到 master 布局

# ==== 特殊功能 ====
# 开关输入法进程
# pkill fcitx5 = 如果 fcitx5 在运行则杀死它；|| fcitx5 = 否则启动它（toggle 效果）
bind = $mainMod, F1, exec, pkill fcitx5 || fcitx5
# 录屏菜单：调用自定义脚本弹出录屏选项
bind = $mainMod, F3, exec, ~/.local/bin/wf-recorder-menu
# 快速存档：调用游戏/会话存档脚本
bind = $mainMod, F5, exec, quicksave
# 快速读档：恢复上一次存档状态
bind = $mainMod, F8, exec, quickload

# 虚假的概览 overview
# 原理：脚本临时切换成 dwindle 布局让所有窗口可见，聚焦后自动恢复原布局
# 详细逻辑见 fake-overview.sh [file:2]
bind = $mainMod, G, exec,  ~/.config/hypr/scripts/fake-overview.sh

# 按照预设切换宽度 switch column width with preset
# colresize +conf = 在 explicit_column_widths 定义的预设值中循环切换
bind = $mainMod, R, layoutmsg, colresize +conf

# 把 column 中的窗口弹出成单独的 column
# promote：将当前窗口从所在列中提取出来，独立成一个新列
bind = $mainMod, N, layoutmsg, promote


# 鼠标滚轮切换聚焦（在 scrolling 布局中左右移动列焦点）
bind = $mainMod, mouse_down, layoutmsg, focus left
bind = $mainMod, mouse_up, layoutmsg, focus right
# swapcol l/r：把当前列与左/右列交换位置
bind = $mainMod Ctrl, H, layoutmsg, swapcol l
bind = $mainMod Ctrl, L, layoutmsg, swapcol r

# 最大化和全屏
# colresize 1 = 把当前列宽撑到 1.0（100% 屏幕宽），视觉上类似最大化
bind = $mainMod, F, layoutmsg, colresize 1      # 当前用法：把列拉到最宽
bind = $mainMod Shift, F, fullscreen             # 真正全屏（无边框、占满整个屏幕）

# 切换工作区
# Shift+滚轮：切换工作区
bind = $mainMod Shift, mouse_down, workspace, -1
bind = $mainMod Shift, mouse_up, workspace, +1
# Shift+Alt+滚轮：把窗口移动到相邻工作区
bind = $mainMod  Alt, mouse_down, movetoworkspace, -1
bind = $mainMod  Alt, mouse_up, movetoworkspace, +1

# 常用程序快捷键
bind = $mainMod, W, exec, $browser       # 打开浏览器
bind = $mainMod, T, exec, $terminal      # 打开终端
bind = $mainMod, Q, killactive,          # 关闭当前聚焦窗口（优雅关闭，等同于点击×）
bind = $mainMod, Z, exec, $menu          # 打开程序启动器（DMS launcher）
bind = $mainMod, E, exec, $fileManager   # 打开文件管理器
bind = $mainMod Ctrl, V, exec, $clipboard # 打开剪贴板管理器（DMS clipboard）
bind = $mainMod Ctrl, W, exec, dms ipc call dankdash wallpaper  # 调用 DMS 壁纸选择器
# 快速终端：--single-instance 复用同一个 kitty 进程，--class 设置窗口 class 名
# 配合下方 windowrule 把 quickterminal 强制浮动 Slash-"/"键
bind = $mainMod, Slash, exec, $terminal --single-instance --class=quickterminal


# 截图（需要 grim + slurp）
# grim -g "$(slurp)"：用 slurp 选区后截图；- 表示输出到 stdout
bind = $mainMod Shift, A, exec, grim -g "$(slurp)" - | wl-copy  # 截图后复制到剪贴板
# 截图后用 satty 打开进行注释/标注编辑
bind = $mainMod Shift, S, exec, grim -g "$(slurp)" - | satty -f -

# 退出 Hyprland：优先调用 hyprshutdown（DMS 生态提供的优雅关机工具），
# 不存在则 fallback 到 hyprctl dispatch exit（直接退出合成器回到 TTY）

# bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit

# 切换当前窗口的浮动状态（平铺 ↔ 浮动）
bind = $mainMod Alt, V, togglefloating,

# 方向键切换焦点
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d

# 数字键直接跳转到指定工作区（1-10，其中 0 对应第 10 个）
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Ctrl+数字：把当前窗口移动到指定工作区（窗口移走，焦点不跟随）
bind = $mainMod Alt, 1, movetoworkspace, 1
bind = $mainMod Alt, 2, movetoworkspace, 2
bind = $mainMod Alt, 3, movetoworkspace, 3
bind = $mainMod Alt, 4, movetoworkspace, 4
bind = $mainMod Alt, 5, movetoworkspace, 5
bind = $mainMod Alt, 6, movetoworkspace, 6
bind = $mainMod Alt, 7, movetoworkspace, 7
bind = $mainMod Alt, 8, movetoworkspace, 8
bind = $mainMod Alt, 9, movetoworkspace, 9
bind = $mainMod Alt, 0, movetoworkspace, 10

# 特殊工作区（Scratchpad，类似隐藏的抽屉工作区），目前已注释
# togglespecialworkspace：显示/隐藏特殊工作区；movetoworkspace special:xxx：送入其中
bind = $mainMod, S, togglespecialworkspace, magic
# bind = $mainMod SHIFT, S, movetoworkspace, special:magic


# 鼠标拖拽窗口操作
# bindm：鼠标专用绑定（按住修饰键 + 鼠标键 拖拽）
# mouse:272 = 鼠标左键，mouse:273 = 鼠标右键
bindm = $mainMod, mouse:272, movewindow    # Super+左键拖拽：移动窗口
bindm = $mainMod, mouse:273, resizewindow  # Super+右键拖拽：缩放窗口

# 笔记本多媒体功能键
# bindel：带 e 标志（按住重复）的 bind，适合需要连续调节的操作
# wpctl：PipeWire 音频控制工具
# set-volume -l 1 = 设置音量，-l 1 表示限制上限为 100%，5%+ = 增加 5%
bindel = ,XF86AudioRaiseVolume, exec, wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+  # 音量+
bindel = ,XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-        # 音量-
bindel = ,XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle             # 静音切换
bindel = ,XF86AudioMicMute, exec, wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle        # 麦克风静音切换
# brightnessctl -e4：平滑调节；-n2：最低不低于 2%，防止屏幕完全变黑
bindel = ,XF86MonBrightnessUp, exec, brightnessctl -e4 -n2 set 5%+    # 亮度+
bindel = ,XF86MonBrightnessDown, exec, brightnessctl -e4 -n2 set 5%-  # 亮度-

# 媒体播放控制（bindl：锁屏状态下也有效）
# playerctl：统一控制当前播放中的媒体程序（Spotify/网易云/浏览器等）
bindl = , XF86AudioNext,  exec, playerctl next          # 下一首
bindl = , XF86AudioPause, exec, playerctl play-pause    # 暂停/播放
bindl = , XF86AudioPlay,  exec, playerctl play-pause    # 播放/暂停
bindl = , XF86AudioPrev,  exec, playerctl previous      # 上一首

##############################
### WINDOWS AND WORKSPACES ###
##############################
# 窗口规则（新式 windowrule 块语法，Hyprland 0.41+ 引入）
# 原理：每个 windowrule 块是"一组匹配条件 + 一组生效效果"
# match:xxx = 匹配条件（props），所有 match 必须同时满足才应用效果
# 支持正则表达式（^ 开头 $ 结尾）
# 效果行（float/no_blur 等）= 匹配成功后执行的操作
# 规则按文件从上到下顺序匹配，多条规则可同时生效（非排他）

windowrule {
    # 全局屏蔽最大化请求：阻止任何应用程序通过协议要求 Hyprland 最大化它
    # 原因：平铺 WM 下"最大化"由布局引擎控制，允许应用自请求最大化会破坏布局
    name = suppress-maximize-events
    match:class = .*                 # 正则 .* = 匹配任意 class，即全局生效
    suppress_event = maximize        # 拦截 maximize 事件，不让它传递给布局引擎
}

windowrule {
    # 修复 XWayland 拖拽 bug：某些 XWayland 应用拖拽时会产生幽灵窗口
    # 特征：class 和 title 都为空，且是 XWayland 浮动、非全屏、非固定的窗口
    # no_focus = true：不让这种窗口获得焦点，防止干扰正常操作
    name = fix-xwayland-drags
    match:class = ^$          # class 为空字符串
    match:title = ^$          # title 为空字符串
    match:xwayland = true     # 是 XWayland 窗口
    match:float = true        # 是浮动窗口
    match:fullscreen = false  # 不是全屏
    match:pin = false         # 不是被固定的窗口
    no_focus = true
}

# Hyprland-run 弹出窗口规则：用于 hyprland-run（一种快速命令启动器）
windowrule {
    name = move-hyprland-run
    match:class = hyprland-run
    move = 20 monitor_h-120  # 位置：距左边 20px，距屏幕底部 120px（monitor_h = 屏幕高度）
    float = yes              # 强制浮动
}

# 按照 Class 匹配的浮动规则组：列出的这些应用全部强制浮动
# 用 | 分隔多个 class，整体用 ^(...)$ 包裹成正则"完全匹配"其中任一
windowrule {
    name = float-by-class
    match:class = ^(linuxqq|com\.gabm\.satty|hyprland-share-picker|org\.quickshell|imv|media_info|video2gif|floating-term|nm-connection-editor|blueman-manager|com\.github\.hluk\.copyq|be\.alexandervanhee\.gradia|org\.pulseaudio\.pavucontrol|org\.gnome\.clocks|org\.gnome\.FileRoller|btrfs-assistant)$
    # 上述 class 含义：
    # com.gabm.satty         = satty 截图注释工具
    # hyprland-share-picker  = Hyprland 屏幕共享选择器
    # org.quickshell         = Quickshell（DMS 状态栏框架）
    # imv                    = 轻量图片查看器
    # media_info             = 媒体信息查看器
    # video2gif              = 视频转 GIF 工具
    # floating-term          = 浮动终端（通用 class 名）
    # nm-connection-editor   = NetworkManager 网络配置编辑器
    # blueman-manager        = 蓝牙设备管理器
    # com.github.hluk.copyq  = CopyQ 剪贴板管理器
    # be.alexandervanhee.gradia = Gradia 截图注释工具
    # org.pulseaudio.pavucontrol = PulseAudio 音量控制面板
    # org.gnome.clocks       = GNOME 时钟
    # org.gnome.FileRoller   = GNOME 归档管理器
    # btrfs-assistant        = Btrfs 快照图形界面
    float = on
}

# 按照 Title 匹配的浮动规则组：中文标题对话框全部浮动
windowrule {
    name = float-by-title
    match:title = ^(文件操作进度|群聊的聊天记录|聊天记录|日历|重命名|Steam 设置|另存为|图片查看器|图片与视频)$
    float = on
}

# quickterminal：Super+/ 唤出的快速悬浮终端，固定浮动显示
windowrule {
	name = quickterminal
	match:class=quickterminal
	float = yes    # 强制浮动（不进入平铺布局）
}

# 修复微信渲染问题：微信在 Hyprland 下开启模糊/阴影常导致黑框或卡顿
windowrule {
	name = wechat
	match:class= wechat
	no_blur = true     # 禁用背景模糊（解决黑框）
	no_shadow = true   # 禁用阴影（减少渲染错误）
        border_size = 0    # 去除边框（视觉更干净）
}

# 浮动窗口关闭 xray 模式
# xray = on 时浮动窗口的模糊是"穿透到底层壁纸"的
# 但如果底层有其他平铺窗口，xray=on 的浮动窗口背景会显示错误内容
# 所以：浮动窗口改用 xray=off，正确采样它下方的所有窗口内容来模糊
windowrule {
    name = optimize-tiled-blur
    match:float = true
    xray = off    # 关闭 X光模式，改为完整采样下方内容
}

####################
### SOURCE FILES ###
####################
# source = 路径：引入外部配置文件，效果等同于把那个文件的内容复制粘贴到此处
# DMS 自动生成文件，不建议手动修改，想覆盖请在 source 行之后再写同名参数

source = ./dms/cursor.conf   # 光标主题与大小（DMS 自动生成）[file:6]
source = ./dms/colors.conf   # 边框/高亮颜色变量（DMS 自动生成，会覆盖上方 col.active_border）[file:5]
source = ./dms/outputs.conf  # 显示器分辨率/刷新率（DMS 自动生成，会覆盖上方 monitor 行）[file:4]

